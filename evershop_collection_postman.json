  "item": [
    {
      "name": "search",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();",
              "console.log(responseBody);",
              "const items = responseBody.eContext.graphqlResponse.e35wux4h7ml3y45nz.products.items;",
              "const productName = items[0].name;",
              "const productSku = items[0].sku;",
              "pm.collectionVariables.set(\"product_name\", productName);",
              "pm.collectionVariables.set(\"product_sku\", productSku);",
              "const searchText = pm.collectionVariables.get(\"search_text\")",
              "pm.test(\"200\",()=>{",
              "    pm.expect(200).eql(pm.response.code)",
              "})",
              "pm.test(\"true\", ()=>{",
              "    pm.expect(true).eql(responseBody.success)",
              "})",
              "pm.test(\"than 0\",()=>{",
              "    pm.expect(items.length).greaterThan(0);",
              "})",
              "pm.test(\"name\",()=>{",
              "    pm.expect(items[0].name).include(searchText)",
              "})",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const searchTextList = [\"Cup\", \"Desk\", \"Black\", \"White\"]\r",
              "\r",
              "function getRandomInteger(min,max){\r",
              "    min = Math.ceil(min);\r",
              "    max = Math.floor(max);\r",
              "    return Math.floor(Math.random()*(max-min +1)) + min;\r",
              "}\r",
              "const searchText = searchTextList[getRandomInteger(0,3)]\r",
              "console.log(searchText);\r",
              "pm.collectionVariables.set(\"search_text\", searchText);\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://demo.evershop.io/search?keyword={{search_text}}&ajax=true",
          "protocol": "https",
          "host": ["demo", "evershop", "io"],
          "path": ["search"],
          "query": [
            {
              "key": "keyword",
              "value": "{{search_text}}"
