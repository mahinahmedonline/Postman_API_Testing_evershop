    {
      "name": "addToCart",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function getRandomInteger(min,max){\r",
              "    min = Math.ceil(min);\r",
              "    max = Math.floor(max);\r",
              "    return Math.floor(Math.random()*(max-min +1)) + min;\r",
              "}\r",
              "\r",
              "const productQty = getRandomInteger(1,5);\r",
              "pm.collectionVariables.set(\"product_qty\", productQty);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var responseBody = pm.response.json();",
              "",
              "pm.test(\"is 200.\", () => {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    const actualSku = responseBody.data.item.product_sku;",
              "    const expectedSku = pm.collectionVariables.get(\"product_sku\");",
              "    const actualQty = responseBody.data.item.qty;",
              "    const preTotalQty = parseInt(pm.collectionVariables.get(\"pre_total_qty\")) || 0;",
              "    const expectedQty = preTotalQty + parseInt(pm.collectionVariables.get(\"product_qty\"));",
              "    pm.collectionVariables.set(\"total_qty\", actualQty);",
              "    pm.collectionVariables.set(\"pre_total_qty\", actualQty);",
              "",
              "    pm.test(\"sku\", () => {",
              "        pm.expect(expectedSku).eql(actualSku);",
              "    });",
              "",
              "    pm.test(\"qty\", () => {",
              "        pm.expect(expectedQty).eql(actualQty);",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"sku\": \"{{product_sku}}\",\r\n    \"qty\": \"{{product_qty}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://demo.evershop.io/api/cart/mine/items",
          "protocol": "https",
          "host": ["demo", "evershop", "io"],
          "path": ["api", "cart", "mine", "items"]
        }
