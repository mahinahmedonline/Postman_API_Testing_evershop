    {
      "name": "post_viewCart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();",
              "const itemsParent = responseBody.eContext.graphqlResponse.e35wux4h7ml3y45oy;",
              "let actualQty;",
              "let removeApiEndPoint = \"\";",
              "try {",
              "    actualQty = parseInt(itemsParent.totalQty);",
              "    removeApiEndPoint = itemsParent.items[0].removeApi;",
              "} catch(error) {",
              "    actualQty = 0;",
              "    console.log(\"cart blank\");",
              "}",
              "const expectedQty = parseInt(pm.collectionVariables.get(\"pre_total_qty\"));",
              "",
              "pm.collectionVariables.set(\"remove_api\", removeApiEndPoint);",
              "pm.collectionVariables.set(\"total_qty\", actualQty);",
              "",
              "pm.test(\"is 200.\", () => {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "pm.test(\"total\", () => {",
              "    pm.expect(expectedQty).to.eql(actualQty);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
